# Dependencies (JSZip is vendored into /vendor, so node_modules is optional)
node_modules/

# Build output / merged packs
dist/
*.zip
!vendor/**/*.zip

# Logs
*.log
npm-debug.log*

# PyInstaller / Python build artifacts
build/
dist/
*.spec
__pycache__/
*.pyc

# Generated installer icon (recreated by installer/build_installer_icon.py)
installer/installer_icon.ico
installer/installer_icon_preview.png

# Playwright MCP test artifacts (accessibility snapshots, console logs)
.playwright-mcp/

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp